# Public web/app URLs
ARCHITECTURE_FLOW_PUBLIC_URL=https://architecture-flow.example.com
ARCHITECTURE_FLOW_API_URL=http://api:4000

# Runtime/auth
AUTH_MODE=header
ARCHITECTURE_FLOW_DEV_USER_EMAIL=
ARCHITECTURE_FLOW_DEV_USER_NAME=
ARCHITECTURE_FLOW_DEV_USER_ROLES=

# Trusted forwarded identity headers should be injected by the reverse proxy.
# Expected headers: x-authentik-email, x-authentik-name, x-authentik-groups
AUTHENTIK_ISSUER=https://auth.example.com/application/o/architecture-flow/

# Database / infra
DATABASE_URL=postgres://architecture_flow:${POSTGRES_PASSWORD}@postgres:5432/architecture_flow
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me

# Flowable
FLOWABLE_BASE_URL=http://flowable:8080/flowable-rest
FLOWABLE_ADMIN_USER=admin
FLOWABLE_ADMIN_PASSWORD=change-me
FLOWABLE_PROCESS_DEFINITION_KEY=architecture-flow-v1

# Intake / worker-executed jobs
GOOGLE_DRIVE_ACCOUNT=nikolaj.floejgaard@gmail.com
GOOGLE_DRIVE_ROOT_NAME=Data - NET
CHROME_BIN=/usr/bin/chromium

# Container ports
WEB_PORT=3000
API_PORT=4000
POSTGRES_PASSWORD=change-me
