<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:flowable="http://flowable.org/bpmn"
  id="Definitions_ArchitectureFlowV1"
  targetNamespace="https://nikolajflojgaard.dev/architecture-flow/bpmn">
  <bpmn:process id="architecture-flow-v1" name="Architecture Flow V1" isExecutable="true">
    <bpmn:documentation>Minimal first workflow mirroring the current work-item lifecycle: new -&gt; triaged -&gt; in progress -&gt; review -&gt; done.</bpmn:documentation>

    <bpmn:startEvent id="StartEvent_NewIntake" name="New intake detected">
      <bpmn:outgoing>Flow_Start_To_Classify</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="ServiceTask_ClassifyIntake" name="Classify intake" flowable:type="external-worker">
      <bpmn:documentation>Determine source type, basic metadata, and whether the item is an API/YAML path or a general design path.</bpmn:documentation>
      <bpmn:incoming>Flow_Start_To_Classify</bpmn:incoming>
      <bpmn:outgoing>Flow_Classify_To_Triage</bpmn:outgoing>
      <bpmn:extensionElements>
        <flowable:field name="topicName">
          <flowable:string><![CDATA[intake.classify]]></flowable:string>
        </flowable:field>
      </bpmn:extensionElements>
    </bpmn:serviceTask>

    <bpmn:userTask id="UserTask_Triage" name="Triage work item" flowable:candidateGroups="architect,admin">
      <bpmn:documentation>Confirm metadata, owner, and framing. This is the move into triaged state.</bpmn:documentation>
      <bpmn:incoming>Flow_Classify_To_Triage</bpmn:incoming>
      <bpmn:outgoing>Flow_Triage_To_ApiGateway</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_IsApiRelated" name="API or YAML-related?">
      <bpmn:documentation>If the work item is API-related, optionally produce/update the OpenAPI/PDF chain before human work continues.</bpmn:documentation>
      <bpmn:incoming>Flow_Triage_To_ApiGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Gateway_To_RenderPdf</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_To_Work</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="ServiceTask_RenderPdf" name="Generate or refresh PDF" flowable:type="external-worker">
      <bpmn:documentation>For YAML/API inputs, invoke the existing OpenAPI renderer and attach the generated PDF artifact.</bpmn:documentation>
      <bpmn:incoming>Flow_Gateway_To_RenderPdf</bpmn:incoming>
      <bpmn:outgoing>Flow_RenderPdf_To_Work</bpmn:outgoing>
      <bpmn:extensionElements>
        <flowable:field name="topicName">
          <flowable:string><![CDATA[artifact.render-pdf]]></flowable:string>
        </flowable:field>
      </bpmn:extensionElements>
    </bpmn:serviceTask>

    <bpmn:userTask id="UserTask_WorkInProgress" name="Produce working artifacts" flowable:candidateGroups="architect,admin">
      <bpmn:documentation>Human working state for KISS/final/OpenAPI generation and cleanup. This matches the in_progress app state.</bpmn:documentation>
      <bpmn:incoming>Flow_Gateway_To_Work</bpmn:incoming>
      <bpmn:incoming>Flow_RenderPdf_To_Work</bpmn:incoming>
      <bpmn:outgoing>Flow_Work_To_Review</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UserTask_Review" name="Review and approve" flowable:candidateGroups="reviewer,architect,admin">
      <bpmn:documentation>Review the current artifacts and decide whether the work is done or needs more iteration.</bpmn:documentation>
      <bpmn:incoming>Flow_Work_To_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_To_Decision</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_ReviewApproved" name="Approved?" default="Flow_Rework_To_Work">
      <bpmn:incoming>Flow_Review_To_Decision</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved_To_End</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rework_To_Work</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Done" name="Done">
      <bpmn:incoming>Flow_Approved_To_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_Classify" sourceRef="StartEvent_NewIntake" targetRef="ServiceTask_ClassifyIntake" />
    <bpmn:sequenceFlow id="Flow_Classify_To_Triage" sourceRef="ServiceTask_ClassifyIntake" targetRef="UserTask_Triage" />
    <bpmn:sequenceFlow id="Flow_Triage_To_ApiGateway" sourceRef="UserTask_Triage" targetRef="Gateway_IsApiRelated" />
    <bpmn:sequenceFlow id="Flow_Gateway_To_RenderPdf" sourceRef="Gateway_IsApiRelated" targetRef="ServiceTask_RenderPdf">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"><![CDATA[${isApiRelated || sourceType == 'yaml-drop'}]]></bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gateway_To_Work" sourceRef="Gateway_IsApiRelated" targetRef="UserTask_WorkInProgress" />
    <bpmn:sequenceFlow id="Flow_RenderPdf_To_Work" sourceRef="ServiceTask_RenderPdf" targetRef="UserTask_WorkInProgress" />
    <bpmn:sequenceFlow id="Flow_Work_To_Review" sourceRef="UserTask_WorkInProgress" targetRef="UserTask_Review" />
    <bpmn:sequenceFlow id="Flow_Review_To_Decision" sourceRef="UserTask_Review" targetRef="Gateway_ReviewApproved" />
    <bpmn:sequenceFlow id="Flow_Approved_To_End" sourceRef="Gateway_ReviewApproved" targetRef="EndEvent_Done">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"><![CDATA[${reviewOutcome == 'approved'}]]></bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Rework_To_Work" sourceRef="Gateway_ReviewApproved" targetRef="UserTask_WorkInProgress">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"><![CDATA[${reviewOutcome != 'approved'}]]></bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ArchitectureFlowV1">
    <bpmndi:BPMNPlane id="BPMNPlane_ArchitectureFlowV1" bpmnElement="architecture-flow-v1">
      <bpmndi:BPMNShape id="Shape_StartEvent_NewIntake" bpmnElement="StartEvent_NewIntake">
        <dc:Bounds x="120" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ServiceTask_ClassifyIntake" bpmnElement="ServiceTask_ClassifyIntake">
        <dc:Bounds x="220" y="158" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UserTask_Triage" bpmnElement="UserTask_Triage">
        <dc:Bounds x="400" y="158" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_IsApiRelated" bpmnElement="Gateway_IsApiRelated" isMarkerVisible="true">
        <dc:Bounds x="590" y="173" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ServiceTask_RenderPdf" bpmnElement="ServiceTask_RenderPdf">
        <dc:Bounds x="700" y="70" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UserTask_WorkInProgress" bpmnElement="UserTask_WorkInProgress">
        <dc:Bounds x="700" y="250" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UserTask_Review" bpmnElement="UserTask_Review">
        <dc:Bounds x="930" y="250" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ReviewApproved" bpmnElement="Gateway_ReviewApproved" isMarkerVisible="true">
        <dc:Bounds x="1130" y="265" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Done" bpmnElement="EndEvent_Done">
        <dc:Bounds x="1250" y="272" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_Classify" bpmnElement="Flow_Start_To_Classify">
        <di:waypoint x="156" y="198" />
        <di:waypoint x="220" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Classify_To_Triage" bpmnElement="Flow_Classify_To_Triage">
        <di:waypoint x="340" y="198" />
        <di:waypoint x="400" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Triage_To_ApiGateway" bpmnElement="Flow_Triage_To_ApiGateway">
        <di:waypoint x="530" y="198" />
        <di:waypoint x="590" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Gateway_To_RenderPdf" bpmnElement="Flow_Gateway_To_RenderPdf">
        <di:waypoint x="615" y="173" />
        <di:waypoint x="615" y="110" />
        <di:waypoint x="700" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Gateway_To_Work" bpmnElement="Flow_Gateway_To_Work">
        <di:waypoint x="615" y="223" />
        <di:waypoint x="615" y="290" />
        <di:waypoint x="700" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_RenderPdf_To_Work" bpmnElement="Flow_RenderPdf_To_Work">
        <di:waypoint x="775" y="150" />
        <di:waypoint x="775" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Work_To_Review" bpmnElement="Flow_Work_To_Review">
        <di:waypoint x="850" y="290" />
        <di:waypoint x="930" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Review_To_Decision" bpmnElement="Flow_Review_To_Decision">
        <di:waypoint x="1070" y="290" />
        <di:waypoint x="1130" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Approved_To_End" bpmnElement="Flow_Approved_To_End">
        <di:waypoint x="1180" y="290" />
        <di:waypoint x="1250" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Rework_To_Work" bpmnElement="Flow_Rework_To_Work">
        <di:waypoint x="1155" y="315" />
        <di:waypoint x="1155" y="430" />
        <di:waypoint x="775" y="430" />
        <di:waypoint x="775" y="330" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
